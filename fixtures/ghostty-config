# Ghostty Configuration
font-family = JetBrains Mono
font-size = 14
theme = catppuccin-mocha

# Window settings
window-decoration = false

# Keybindings
keybind = cmd+t=new_tab
keybind = cmd+shift+d=new_split:down
keybind = cmd+shift+r=new_split:right
keybind = cmd+w=close_surface
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = cmd+shift+enter=toggle_fullscreen
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size
